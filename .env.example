# Casdoor OIDC configuration for the management backend.
CASDOOR_ISSUER=https://casdoor.example.com
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_REDIRECT_URI=https://blog.example.com/api/auth/casdoor/callback

# Only this exact Casdoor preferred_username may enter /admin.
CASDOOR_ALLOWED_USER=Ruawd

# At least 32 random characters. Example: openssl rand -base64 48
SESSION_SECRET=

# Bangumi access tokens saved in the admin console are encrypted with SESSION_SECRET.
# Rotating this secret requires entering the Bangumi token again.

# Docker uses this path. For a direct Node deployment, ./data/blog.sqlite also works.
DATABASE_PATH=/app/data/blog.sqlite

# Keep true behind HTTPS. Set false only for a trusted local HTTP environment.
COOKIE_SECURE=true

# Port exposed on the server by Docker Compose.
APP_PORT=3000
